# Atlantiplex Studio SaaS - Environment Variables

# Server Configuration
PORT=3000
NODE_ENV=production

# Security
JWT_SECRET=your-super-secret-jwt-key-min-32-characters

# Stripe Configuration
STRIPE_SECRET=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Domain Configuration
FRONTEND_URL=https://verilysovereign.online
API_URL=https://api.verilysovereign.online

# Database (Optional - uses JSON files by default)
DATABASE_URL=sqlite:///studio.db

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# OBS Integration (Optional)
OBS_WEBSOCKET_HOST=localhost
OBS_WEBSOCKET_PORT=4455
OBS_WEBSOCKET_PASSWORD=your-obs-password